# Fastlane Fastfile — TestFlight deployment via App Store Connect API Key.
# CI flow: cert + sigh → unsigned archive → manual export with dist profile → upload
# The unsigned archive avoids signing issues on SPM dependency targets (MetalSplatter).
default_platform(:ios)

REPO_ROOT = File.expand_path("..", Dir.pwd)

platform :ios do
  def api_key
    app_store_connect_api_key(
      key_id: ENV["ASC_API_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_API_KEY_CONTENT"],
      duration: 1200,
      in_house: false
    )
  end

  desc "Build and upload to TestFlight (CI uses this)"
  lane :beta do
    key_path = "/tmp/AuthKey_#{ENV['ASC_API_KEY_ID']}.p8"
    File.write(key_path, ENV['ASC_API_KEY_CONTENT'])
    team_id = ENV.fetch("APPLE_TEAM_ID", "")
    app_id = "cloud.dkroeker.GaussianSplattingViewer"

    # Create/get distribution certificate — force: true revokes orphaned
    # certs from previous ephemeral CI runners that hold no private key locally
    cert(
      api_key: api_key,
      team_id: team_id,
      force: true
    )

    # Create/get App Store distribution provisioning profile
    profile_uuid = sigh(
      api_key: api_key,
      app_identifier: app_id
    )

    profile_name = ENV["SIGH_NAME"] || "#{app_id} AppStore"

    Dir.chdir(REPO_ROOT) do
      archive_path = "build/GaussianSplattingViewer.xcarchive"
      ipa_output_dir = "build/ipa"
      sh("rm -rf build && mkdir -p #{ipa_output_dir}")

      # Archive without signing — avoids "does not support provisioning profiles"
      # on MetalSplatter SPM dependency targets.
      # No -allowProvisioningUpdates: unnecessary with CODE_SIGNING_ALLOWED=NO,
      # and can cause xcodebuild to hang waiting for Apple's provisioning service.
      sh("xcodebuild archive " \
         "-project GaussianSplattingViewer.xcodeproj " \
         "-scheme GaussianSplattingViewer " \
         "-configuration Release " \
         "-destination 'generic/platform=iOS' " \
         "-archivePath #{archive_path} " \
         "-skipPackagePluginValidation " \
         "-skipMacroValidation " \
         "CODE_SIGNING_ALLOWED=NO " \
         "CODE_SIGNING_REQUIRED=NO")

      # Manual export — signs only the app target with the dist cert+profile.
      # No -allowProvisioningUpdates: the profile is already installed locally,
      # and this flag causes xcodebuild to hang waiting for Apple's server.
      export_plist = "/tmp/ExportOptions.plist"
      File.write(export_plist, <<~PLIST)
        <?xml version="1.0" encoding="UTF-8"?>
        <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
        <plist version="1.0">
        <dict>
          <key>method</key>
          <string>app-store-connect</string>
          <key>signingStyle</key>
          <string>manual</string>
          <key>provisioningProfiles</key>
          <dict>
            <key>#{app_id}</key>
            <string>#{profile_name}</string>
          </dict>
          <key>teamID</key>
          <string>#{team_id}</string>
          <key>uploadBitcode</key>
          <false/>
          <key>uploadSymbols</key>
          <true/>
        </dict>
        </plist>
      PLIST

      sh("xcodebuild -exportArchive " \
         "-archivePath #{archive_path} " \
         "-exportPath #{ipa_output_dir} " \
         "-exportOptionsPlist #{export_plist}")
    end

    upload_to_testflight(
      api_key: api_key,
      ipa: File.join(REPO_ROOT, "build/ipa/GaussianSplattingViewer.ipa"),
      skip_waiting_for_build_processing: true
    )
  end
end
