# Fastlane Fastfile — TestFlight deployment via App Store Connect API Key.
# CI flow: cert + sigh → unsigned archive → manual codesign + IPA package → upload_to_testflight
#
# Bypasses xcodebuild -exportArchive which hangs IDEDistribution on GitHub Actions
# macOS runners (keychain partition list issue). Instead: codesign the .app directly,
# package as IPA manually, upload via fastlane's upload_to_testflight (iTMSTransporter).
default_platform(:ios)

REPO_ROOT = File.expand_path("..", Dir.pwd)

platform :ios do
  def api_key
    app_store_connect_api_key(
      key_id: ENV["ASC_API_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_API_KEY_CONTENT"],
      duration: 1200,
      in_house: false
    )
  end

  desc "Build and upload to TestFlight (CI uses this)"
  lane :beta do
    key_path = "/tmp/AuthKey_#{ENV['ASC_API_KEY_ID']}.p8"
    File.write(key_path, ENV['ASC_API_KEY_CONTENT'])
    team_id = ENV.fetch("APPLE_TEAM_ID", "")
    app_id = "cloud.dkroeker.GaussianSplattingViewer"

    # Create/get distribution certificate — force: true revokes orphaned
    # certs from previous ephemeral CI runners that hold no private key locally.
    cert(
      api_key: api_key,
      team_id: team_id,
      force: true,
      keychain_password: ""
    )

    # Create/get App Store distribution provisioning profile
    sigh(
      api_key: api_key,
      app_identifier: app_id
    )

    profile_uuid = ENV["SIGH_UDID"]
    profile_path = ENV["SIGH_PROFILE_PATH"]

    # Keychain: unlock + set partition list so codesign (and IDEDistribution
    # if ever used) can access the private key without a GUI prompt.
    # This is the fix for the silent hang on GitHub Actions macOS runners.
    sh("security unlock-keychain -p '' ~/Library/Keychains/login.keychain-db 2>/dev/null || true")
    sh("security set-key-partition-list -S apple-tool:,apple:,codesign: -s -k '' ~/Library/Keychains/login.keychain-db 2>/dev/null || true")

    # Find the distribution cert identity name for codesign.
    # Xcode 26 names it "Apple Distribution", older Xcode "iPhone Distribution".
    identities = sh("security find-identity -v -p codesigning ~/Library/Keychains/login.keychain-db")
    UI.important("Available codesigning identities:\n#{identities}")
    cert_identity = identities.lines.select { |l| l =~ /Distribution/i }.first&.match(/"([^"]+)"/)&.[](1) || ""
    UI.user_error!("No Distribution certificate found in keychain") if cert_identity.empty?

    Dir.chdir(REPO_ROOT) do
      archive_path = "build/GaussianSplattingViewer.xcarchive"
      ipa_output_dir = "build/ipa"
      sh("rm -rf build && mkdir -p #{ipa_output_dir}")

      # Step 1: Archive without signing — avoids "does not support provisioning profiles"
      # on MetalSplatter SPM dependency targets.
      UI.message("=== Archiving (unsigned) ===")
      sh("xcodebuild archive " \
         "-project GaussianSplattingViewer.xcodeproj " \
         "-scheme GaussianSplattingViewer " \
         "-configuration Release " \
         "-destination 'generic/platform=iOS' " \
         "-archivePath #{archive_path} " \
         "-skipPackagePluginValidation " \
         "-skipMacroValidation " \
         "CODE_SIGNING_ALLOWED=NO " \
         "CODE_SIGNING_REQUIRED=NO " \
         "2>&1")

      # Step 2: Manually codesign the .app and package as IPA.
      # Bypasses xcodebuild -exportArchive which hangs IDEDistribution.
      app_path = "#{archive_path}/Products/Applications/GaussianSplattingViewer.app"
      ipa_path = "#{ipa_output_dir}/GaussianSplattingViewer.ipa"

      # Embed provisioning profile into the .app
      sh("cp #{profile_path} #{app_path}/embedded.mobileprovision")

      # Codesign — use --force to replace the unsigned copy from archive.
      # Entitlements: the archive generates .entitlements only if code signing
      # was active during archive. Since we archive unsigned, we codesign
      # without --entitlements (the profile carries the entitlements).
      UI.message("=== Codesigning .app ===")
      sh("codesign -f -s '#{cert_identity}' " \
         "-i #{app_id} " \
         "--timestamp=none " \
         "#{app_path} 2>&1")

      # Verify signature
      sh("codesign -vv #{app_path} 2>&1")

      # Package as IPA
      UI.message("=== Packaging IPA ===")
      sh("rm -rf Payload && mkdir Payload")
      sh("cp -r #{app_path} Payload/")
      sh("zip -r #{ipa_path} Payload")
      sh("rm -rf Payload")

      UI.message("=== IPA ready: #{ipa_path} ===")
    end

    # Upload to TestFlight — uses iTMSTransporter, not exportArchive.
    upload_to_testflight(
      api_key: api_key,
      ipa: File.join(REPO_ROOT, "build/ipa/GaussianSplattingViewer.ipa"),
      skip_waiting_for_build_processing: true
    )
  end
end
