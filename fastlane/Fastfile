# Fastlane Fastfile — TestFlight deployment via App Store Connect API Key.
# CI pattern: cert + sigh create distribution cert/profile, then build_app with manual signing.
# This avoids the "no devices" error — automatic signing tries to create development profiles.
default_platform(:ios)

REPO_ROOT = File.expand_path("..", Dir.pwd)

platform :ios do
  def api_key
    app_store_connect_api_key(
      key_id: ENV["ASC_API_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_API_KEY_CONTENT"],
      duration: 1200,
      in_house: false
    )
  end

  desc "Build and upload to TestFlight (CI uses this)"
  lane :beta do
    key_path = "/tmp/AuthKey_#{ENV['ASC_API_KEY_ID']}.p8"
    File.write(key_path, ENV['ASC_API_KEY_CONTENT'])
    team_id = ENV.fetch("APPLE_TEAM_ID", "")
    app_id = "cloud.dkroeker.GaussianSplattingViewer"

    # Create/get distribution certificate (installs to CI keychain)
    cert(
      api_key: api_key,
      team_id: team_id
    )

    # Create/get App Store distribution provisioning profile
    profile_uuid = sigh(
      api_key: api_key,
      app_identifier: app_id,
      export_method: "app-store"
    )

    build_app(
      project: File.join(REPO_ROOT, "GaussianSplattingViewer.xcodeproj"),
      scheme: "GaussianSplattingViewer",
      configuration: "Release",
      export_method: "app-store",
      export_team_id: team_id,
      output_directory: File.join(REPO_ROOT, "build/ipa"),
      output_name: "GaussianSplattingViewer.ipa",
      xcargs: "-allowProvisioningUpdates " \
              "-authenticationKeyPath #{key_path} " \
              "-authenticationKeyID #{ENV['ASC_API_KEY_ID']} " \
              "-authenticationKeyIssuerID #{ENV['ASC_ISSUER_ID']} " \
              "CODE_SIGN_STYLE=Manual " \
              "PROVISIONING_PROFILE_SPECIFIER='#{profile_uuid}'",
      include_bitcode: false,
      include_symbols: true
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: File.join(REPO_ROOT, "build/ipa/GaussianSplattingViewer.ipa"),
      skip_waiting_for_build_processing: true
    )
  end
end
