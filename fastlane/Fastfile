# Fastlane Fastfile — TestFlight deployment via App Store Connect API Key.
# CI flow: cert + sigh → unsigned archive → codesign + package IPA → altool upload
# Bypasses xcodebuild -exportArchive which hangs contacting Apple servers.
default_platform(:ios)

REPO_ROOT = File.expand_path("..", Dir.pwd)

platform :ios do
  def api_key
    app_store_connect_api_key(
      key_id: ENV["ASC_API_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_API_KEY_CONTENT"],
      duration: 1200,
      in_house: false
    )
  end

  desc "Build and upload to TestFlight (CI uses this)"
  lane :beta do
    key_path = "/tmp/AuthKey_#{ENV['ASC_API_KEY_ID']}.p8"
    File.write(key_path, ENV['ASC_API_KEY_CONTENT'])
    team_id = ENV.fetch("APPLE_TEAM_ID", "")
    app_id = "cloud.dkroeker.GaussianSplattingViewer"

    # Revoke orphaned certs from previous ephemeral CI runners
    sh("python3 #{File.join(REPO_ROOT, 'scripts/revoke_certs.py')} 2>/dev/null || true")

    # Create/get distribution certificate
    cert(
      api_key: api_key,
      team_id: team_id,
      force: true
    )

    # Unlock keychain so codesign can access the private key
    sh("security unlock-keychain -p '' ~/Library/Keychains/login.keychain-db 2>/dev/null || true")
    sh("security set-keychain-settings -t 3600 ~/Library/Keychains/login.keychain-db 2>/dev/null || true")

    # Create/get App Store distribution provisioning profile
    profile_uuid = sigh(
      api_key: api_key,
      app_identifier: app_id
    )

    profile_path = ENV["SIGH_PROFILE_PATH"]
    profile_name = ENV["SIGH_NAME"] || "#{app_id} AppStore"

    Dir.chdir(REPO_ROOT) do
      archive_path = "build/GaussianSplattingViewer.xcarchive"
      ipa_output_dir = "build/ipa"
      sh("rm -rf build && mkdir -p #{ipa_output_dir}")

      # Archive without signing — avoids "does not support provisioning profiles"
      # on MetalSplatter SPM dependency targets.
      UI.message("=== Archiving (unsigned) ===")
      sh("xcodebuild archive " \
         "-project GaussianSplattingViewer.xcodeproj " \
         "-scheme GaussianSplattingViewer " \
         "-configuration Release " \
         "-destination 'generic/platform=iOS' " \
         "-archivePath #{archive_path} " \
         "-skipPackagePluginValidation " \
         "-skipMacroValidation " \
         "CODE_SIGNING_ALLOWED=NO " \
         "CODE_SIGNING_REQUIRED=NO " \
         "2>&1")

      # Manually sign the .app and package as IPA.
      # This bypasses xcodebuild -exportArchive which hangs contacting Apple.
      app_path = "#{archive_path}/Products/Applications/GaussianSplattingViewer.app"
      ipa_path = "#{ipa_output_dir}/GaussianSplattingViewer.ipa"

      # Install provisioning profile
      sh("cp #{profile_path} ~/Library/MobileDevice/Provisioning\\ Profiles/ 2>/dev/null || true")

      # Codesign the app with the distribution cert and profile
      sh("codesign -f -s 'iPhone Distribution' " \
         "--entitlements #{app_path}/GaussianSplattingViewer.entitlements " \
         "--provisioning-profile #{profile_uuid} " \
         "#{app_path} 2>&1 || " \
         "codesign -f -s 'iPhone Distribution' #{app_path} 2>&1")

      # Package as IPA
      sh("mkdir -p Payload")
      sh("cp -r #{app_path} Payload/")
      sh("zip -r #{ipa_path} Payload")
      sh("rm -rf Payload")
    end

    # Upload to TestFlight via altool (bypasses xcodebuild export entirely)
    sh("xcrun altool --upload-app " \
       "-f #{File.join(REPO_ROOT, 'build/ipa/GaussianSplattingViewer.ipa')} " \
       "-t ios " \
       "--apiKey #{ENV['ASC_API_KEY_ID']} " \
       "--apiIssuer #{ENV['ASC_ISSUER_ID']} " \
       "--type testflight " \
       "2>&1")
  end
end
