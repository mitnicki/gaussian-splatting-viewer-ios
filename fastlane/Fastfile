# Fastlane Fastfile — TestFlight deployment via App Store Connect API Key.
#
# Uses Xcode 14+ authentication key signing: the .p8 is written to a temp file,
# and xcodebuild uses -authenticationKeyPath/-ID/-IssuerID for auto-provisioning.
# This avoids needing an Apple ID account logged into Xcode on the CI runner.
#
# Required GitHub secrets (set by Dennis):
#   APP_STORE_CONNECT_KEY_ID       — Key ID from App Store Connect
#   APP_STORE_CONNECT_ISSUER_ID     — Issuer ID from App Store Connect
#   APP_STORE_CONNECT_P8_CONTENTS   — Contents of the .p8 file (raw or base64)
#   APPLE_TEAM_ID                   — Team ID from Apple Developer Portal

default_platform(:ios)

platform :ios do
  def api_key
    app_store_connect_api_key(
      key_id: ENV["ASC_API_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_API_KEY_CONTENT"],
      duration: 1200,
      in_house: false
    )
  end

  desc "Build and upload to TestFlight (CI uses this)"
  lane :beta do
    # Write the .p8 key file for Xcode auto-provisioning
    key_path = "/tmp/AuthKey_#{ENV['ASC_API_KEY_ID']}.p8"
    File.write(key_path, ENV['ASC_API_KEY_CONTENT'])

    build_app(
      project: "GaussianSplattingViewer.xcodeproj",
      scheme: "GaussianSplattingViewer",
      configuration: "Release",
      export_method: "app-store",
      export_team_id: ENV.fetch("APPLE_TEAM_ID", ""),
      xcargs: "-allowProvisioningUpdates " \
              "-authenticationKeyPath #{key_path} " \
              "-authenticationKeyID #{ENV['ASC_API_KEY_ID']} " \
              "-authenticationKeyIssuerID #{ENV['ASC_ISSUER_ID']} " \
              "DEVELOPMENT_TEAM=#{ENV.fetch('APPLE_TEAM_ID', '')} " \
              "CODE_SIGN_STYLE=Automatic"
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
