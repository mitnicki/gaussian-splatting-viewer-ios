# Fastlane Fastfile — TestFlight deployment via App Store Connect API Key.
# Uses a temporary keychain with known password to fix codesign hang on CI.
default_platform(:ios)

REPO_ROOT = File.expand_path("..", Dir.pwd)
KEYCHAIN_NAME = "fastlane_tmp"
KEYCHAIN_PASSWORD = "tempkey123"

platform :ios do
  def api_key
    app_store_connect_api_key(
      key_id: ENV["ASC_API_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_API_KEY_CONTENT"],
      duration: 1200,
      in_house: false
    )
  end

  desc "Build and upload to TestFlight (CI uses this)"
  lane :beta do
    key_path = "/tmp/AuthKey_#{ENV['ASC_API_KEY_ID']}.p8"
    File.write(key_path, ENV['ASC_API_KEY_CONTENT'])
    team_id = ENV.fetch("APPLE_TEAM_ID", "")
    app_id = "cloud.dkroeker.GaussianSplattingViewer"
    keychain_path = "#{Dir.home}/Library/Keychains/#{KEYCHAIN_NAME}.keychain-db"

    # Create a temporary keychain with a known password.
    # The GitHub Actions login keychain has an unknown password, so
    # security set-key-partition-list fails and codesign hangs.
    sh("security delete-keychain #{KEYCHAIN_NAME}.keychain-db 2>/dev/null || true")
    sh("security create-keychain -p #{KEYCHAIN_PASSWORD} #{KEYCHAIN_NAME}.keychain-db")
    sh("security set-keychain-settings -t 3600 -u #{KEYCHAIN_NAME}.keychain-db")
    sh("security unlock-keychain -p #{KEYCHAIN_PASSWORD} #{KEYCHAIN_NAME}.keychain-db")
    # Add temp keychain to the search list so cert() can import into it
    sh("security list-keychains -d user -s #{KEYCHAIN_NAME}.keychain-db login.keychain-db")

    # Create/get distribution certificate in the temp keychain
    cert(
      api_key: api_key,
      team_id: team_id,
      force: true,
      keychain_path: keychain_path,
      keychain_password: KEYCHAIN_PASSWORD
    )

    # Set partition list so codesign can access the key without UI prompt
    sh("security set-key-partition-list -S apple-tool:,apple:,codesign: -s -k #{KEYCHAIN_PASSWORD} #{KEYCHAIN_NAME}.keychain-db")

    # Find the distribution cert identity name for codesign
    identities = sh("security find-identity -v -p codesigning #{keychain_path}")
    UI.important("Available codesigning identities:\n#{identities}")
    cert_identity = identities.lines.select { |l| l =~ /Distribution/i }.first&.match(/\"([^\"]+)\"/)&.[](1) || ""
    UI.user_error!("No Distribution certificate found in keychain") if cert_identity.empty?

    # Create/get App Store distribution provisioning profile
    sigh(
      api_key: api_key,
      app_identifier: app_id
    )

    profile_path = lane_context[SharedValues::SIGH_PROFILE_PATH] || ENV["SIGH_PROFILE_PATH"]
    profile_name = lane_context[SharedValues::SIGH_NAME] || ENV["SIGH_NAME"] || "#{app_id} AppStore"

    Dir.chdir(REPO_ROOT) do
      archive_path = "build/GaussianSplattingViewer.xcarchive"
      ipa_output_dir = "build/ipa"
      sh("rm -rf build && mkdir -p #{ipa_output_dir}")

      # Archive without signing
      UI.message("=== Archiving (unsigned) ===")
      sh("xcodebuild archive " \
         "-project GaussianSplattingViewer.xcodeproj " \
         "-scheme GaussianSplattingViewer " \
         "-configuration Release " \
         "-destination 'generic/platform=iOS' " \
         "-archivePath #{archive_path} " \
         "-skipPackagePluginValidation " \
         "-skipMacroValidation " \
         "CODE_SIGNING_ALLOWED=NO " \
         "CODE_SIGNING_REQUIRED=NO " \
         "2>&1")

      # Manually codesign the .app and package as IPA.
      app_path = "#{archive_path}/Products/Applications/GaussianSplattingViewer.app"
      ipa_path = "#{ipa_output_dir}/GaussianSplattingViewer.ipa"

      # Embed provisioning profile
      sh("cp #{profile_path} #{app_path}/embedded.mobileprovision")

      # Codesign
      UI.message("=== Codesigning .app with '#{cert_identity}' ===")
      sh("codesign -f -s '#{cert_identity}' -i #{app_id} --timestamp=none #{app_path} 2>&1")

      # Verify
      sh("codesign -vv #{app_path} 2>&1")

      # Package as IPA
      UI.message("=== Packaging IPA ===")
      sh("rm -rf Payload && mkdir Payload")
      sh("cp -r #{app_path} Payload/")
      sh("zip -r #{ipa_path} Payload")
      sh("rm -rf Payload")

      UI.message("=== IPA ready: #{ipa_path} ===")
    end

    upload_to_testflight(
      api_key: api_key,
      ipa: File.join(REPO_ROOT, "build/ipa/GaussianSplattingViewer.ipa"),
      skip_waiting_for_build_processing: true
    )
  end
end
