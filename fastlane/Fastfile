# Fastlane Fastfile — build and deployment lanes for the Gaussian Splatting Viewer.
# M3: TestFlight/App Store distribution.
#
# Prerequisites:
#   1. Apple Developer Account (~99 EUR/yr)
#   2. xcodegen installed:  brew install xcodegen
#   3. fastlane installed:   brew install fastlane
#   4. Fill in fastlane/Appfile with your Apple ID + team ID
#   5. Run:  fastlane match development  (sets up code signing)
#
# Usage:
#   fastlane beta    # Build and upload to TestFlight
#   fastlane release # Build and upload to App Store

default_platform(:ios)

platform :ios do
  desc "Generate the Xcode project from project.yml"
  private_lane :generate_project do
    sh("xcodegen generate")
  end

  desc "Build the app and upload to TestFlight"
  desc "Requires: fastlane match development, fastlane match appstore"
  lane :beta do
    generate_project

    build_app(
      project: "GaussianSplattingViewer.xcodeproj",
      scheme: "GaussianSplattingViewer",
      configuration: "Release",
      export_method: "app-store",
      include_bitcode: false
    )

    upload_to_testflight(
      skip_waiting_for_build_processing: true
    )
  end

  desc "Build the app and upload to App Store Connect"
  desc "Requires: fastlane match appstore"
  lane :release do
    generate_project

    build_app(
      project: "GaussianSplattingViewer.xcodeproj",
      scheme: "GaussianSplattingViewer",
      configuration: "Release",
      export_method: "app-store",
      include_bitcode: false
    )

    upload_to_app_store(
      skip_screenshots: true,
      skip_metadata: true
    )
  end

  desc "Generate localized screenshots for all device sizes"
  lane :screenshots do
    generate_project
    capture_screenshots
  end
end
