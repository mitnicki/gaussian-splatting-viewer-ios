# Fastlane Fastfile — TestFlight deployment via App Store Connect API Key.
# CI flow: cert + sigh → gym (archive+export) → upload_to_testflight
# gym handles the export with proper API key auth and timeout management.
default_platform(:ios)

REPO_ROOT = File.expand_path("..", Dir.pwd)

platform :ios do
  def api_key
    app_store_connect_api_key(
      key_id: ENV["ASC_API_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_API_KEY_CONTENT"],
      duration: 1200,
      in_house: false
    )
  end

  desc "Build and upload to TestFlight (CI uses this)"
  lane :beta do
    key_path = "/tmp/AuthKey_#{ENV['ASC_API_KEY_ID']}.p8"
    File.write(key_path, ENV['ASC_API_KEY_CONTENT'])
    team_id = ENV.fetch("APPLE_TEAM_ID", "")
    app_id = "cloud.dkroeker.GaussianSplattingViewer"

    # Revoke orphaned certs from previous ephemeral CI runners
    sh("python3 #{File.join(REPO_ROOT, 'scripts/revoke_certs.py')}") rescue nil

    # Create/get distribution certificate
    cert(
      api_key: api_key,
      team_id: team_id,
      force: true
    )

    # Create/get App Store distribution provisioning profile
    profile_uuid = sigh(
      api_key: api_key,
      app_identifier: app_id
    )

    profile_name = ENV["SIGH_NAME"] || "#{app_id} AppStore"

    # Use gym to archive + export in one step.
    # export_method app-store uses the API key for provisioning.
    # include_bitcode false — Xcode 26 dropped bitcode support.
    gym(
      project: File.join(REPO_ROOT, "GaussianSplattingViewer.xcodeproj"),
      scheme: "GaussianSplattingViewer",
      configuration: "Release",
      export_method: "app-store",
      export_team_id: team_id,
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: {
          app_id => profile_name
        },
        uploadBitcode: false,
        uploadSymbols: true
      },
      output_directory: File.join(REPO_ROOT, "build/ipa"),
      output_name: "GaussianSplattingViewer.ipa",
      xcargs: "-allowProvisioningUpdates " \
              "-authenticationKeyPath #{key_path} " \
              "-authenticationKeyID #{ENV['ASC_API_KEY_ID']} " \
              "-authenticationKeyIssuerID #{ENV['ASC_ISSUER_ID']} " \
              "CODE_SIGNING_ALLOWED=NO",
      include_bitcode: false,
      include_symbols: true,
      clean: true
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: File.join(REPO_ROOT, "build/ipa/GaussianSplattingViewer.ipa"),
      skip_waiting_for_build_processing: true
    )
  end
end
