# Fastlane Fastfile — TestFlight deployment via App Store Connect API Key.
# No 2FA needed — the API key authenticates everything.
# No match/cert git repo needed — certs are created on the CI runner directly.
#
# Required GitHub secrets (set by Dennis):
#   APP_STORE_CONNECT_KEY_ID       — Key ID from App Store Connect
#   APP_STORE_CONNECT_ISSUER_ID     — Issuer ID from App Store Connect
#   APP_STORE_CONNECT_P8_CONTENTS   — Contents of the .p8 file (base64 or raw)
#   APPLE_TEAM_ID                   — Team ID from Apple Developer Portal

default_platform(:ios)

platform :ios do
  def api_key
    app_store_connect_api_key(
      key_id: ENV["ASC_API_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_API_KEY_CONTENT"],
      duration: 1200,
      in_house: false
    )
  end

  desc "Build and upload to TestFlight (CI uses this)"
  lane :beta do
    # CI workflow already ran `xcodegen generate` from repo root before invoking fastlane.
    # fastlane runs from the repo root (not fastlane/ subdir) — the workflow's working directory.

    # Create/fetch distribution certificate + provisioning profile directly
    # (no separate git repo needed — certs live on the ephemeral CI runner)
    get_certificates(
      api_key: api_key,
      type: "appstore",
      app_identifier: "cloud.dkroeker.GaussianSplattingViewer"
    )

    get_provisioning_profile(
      api_key: api_key,
      type: "appstore",
      app_identifier: "cloud.dkroeker.GaussianSplattingViewer"
    )

    build_app(
      project: "GaussianSplattingViewer.xcodeproj",
      scheme: "GaussianSplattingViewer",
      configuration: "Release",
      export_method: "app-store",
      include_bitcode: false,
      xcargs: "DEVELOPMENT_TEAM=#{ENV.fetch('APPLE_TEAM_ID', '')}"
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
