# Fastlane Fastfile — TestFlight deployment via App Store Connect API Key.
#
# Two-phase build:
#   1. Archive without code signing (CODE_SIGNING_ALLOWED=NO)
#   2. Export with -allowProvisioningUpdates + auth key (creates App Store dist profile)
#
# This avoids the "no devices" error from automatic signing trying to create
# a development profile instead of an App Store distribution profile.
#
# Required GitHub secrets (set by Dennis):
#   APP_STORE_CONNECT_KEY_ID       — Key ID
#   APP_STORE_CONNECT_ISSUER_ID     — Issuer ID
#   APP_STORE_CONNECT_P8_CONTENTS   — .p8 private key contents
#   APPLE_TEAM_ID                   — Team ID

default_platform(:ios)

platform :ios do
  def api_key
    app_store_connect_api_key(
      key_id: ENV["ASC_API_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_API_KEY_CONTENT"],
      duration: 1200,
      in_house: false
    )
  end

  desc "Build and upload to TestFlight (CI uses this)"
  lane :beta do
    # CI workflow already ran `xcodegen generate` from repo root.

    # Write .p8 key file for Xcode auto-provisioning
    key_path = "/tmp/AuthKey_#{ENV['ASC_API_KEY_ID']}.p8"
    File.write(key_path, ENV['ASC_API_KEY_CONTENT'])

    # Write export options plist for app-store distribution
    export_plist = "/tmp/ExportOptions.plist"
    File.write(export_plist, <<~PLIST)
      <?xml version="1.0" encoding="UTF-8"?>
      <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
      <plist version="1.0">
      <dict>
        <key>method</key>
        <string>app-store</string>
        <key>signingStyle</key>
        <string>automatic</string>
        <key>teamID</key>
        <string>#{ENV.fetch('APPLE_TEAM_ID', '')}</string>
        <key>uploadBitcode</key>
        <false/>
        <key>uploadSymbols</key>
        <true/>
      </dict>
      </plist>
    PLIST

    archive_path = "build/GaussianSplattingViewer.xcarchive"
    ipa_output_dir = "build/ipa"
    sh("rm -rf build && mkdir -p #{ipa_output_dir}")

    # Phase 1: Archive without signing
    sh("xcodebuild archive " \
       "-project GaussianSplattingViewer.xcodeproj " \
       "-scheme GaussianSplattingViewer " \
       "-configuration Release " \
       "-destination 'generic/platform=iOS' " \
       "-archivePath #{archive_path} " \
       "CODE_SIGNING_ALLOWED=NO")

    # Phase 2: Export with App Store signing using auth key
    sh("xcodebuild -exportArchive " \
       "-archivePath #{archive_path} " \
       "-exportPath #{ipa_output_dir} " \
       "-exportOptionsPlist #{export_plist} " \
       "-allowProvisioningUpdates " \
       "-authenticationKeyPath #{key_path} " \
       "-authenticationKeyID #{ENV['ASC_API_KEY_ID']} " \
       "-authenticationKeyIssuerID #{ENV['ASC_ISSUER_ID']}")

    # Upload to TestFlight
    upload_to_testflight(
      api_key: api_key,
      ipa: "#{ipa_output_dir}/GaussianSplattingViewer.ipa",
      skip_waiting_for_build_processing: true
    )
  end
end
